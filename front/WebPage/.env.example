# API 베이스 URL (슬래시 없이). 빈 값 = 개발 시 Vite proxy → http://localhost:8080
# VITE_API_BASE_URL=
VITE_API_BASE_URL=https://capston.p-e.kr

# 구글 OAuth (로그인 버튼) — Google Cloud 콘솔에 등록한 값과 동일해야 함
# 비우면 redirect는 현재 origin + /auth/callback (예: http://localhost:5173/auth/callback)
# VITE_GOOGLE_CLIENT_ID=
# VITE_GOOGLE_REDIRECT_URI=
