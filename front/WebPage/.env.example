# API 베이스 URL (슬래시 없이). 빈 값 = 개발 시 Vite proxy → http://localhost:8080
# VITE_API_BASE_URL=
VITE_API_BASE_URL=https://capston.p-e.kr

# 구글 OAuth (로그인 버튼) — Google Cloud 콘솔「승인된 리디렉션 URI」와 바이트 단위로 동일해야 함
# 비우면 redirect는 현재 origin + /auth/callback (로컬: http://localhost:5173/auth/callback)
# Vercel 배포 시 콘솔에 예: https://2026-growth-front-deploy.vercel.app/auth/callback
# VITE_GOOGLE_CLIENT_ID=
# Vercel에서 origin이 고정이면 아래를 명시해도 됨 (비우면 위 URL과 동일하게 자동)
# VITE_GOOGLE_REDIRECT_URI=https://2026-growth-front-deploy.vercel.app/auth/callback
